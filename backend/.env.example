# ===========================================
# Backend & Pinecone script ortam değişkenleri
# Kopyalayın: .env.example -> .env
# .env dosyası: backend/.env (backend klasörü içinde)
# ===========================================

# ----- Ollama (chat API) -----
# Ollama sunucusu adresi. Varsayılan: http://localhost:11434
OLLAMA_URL=http://localhost:11434

# ----- Pinecone (insert-vectors script - Integrated Embedding) -----
# Pinecone API anahtarı - https://app.pinecone.io/ üzerinden alın
PINECONE_API_KEY=

# Pinecone index adı (Integrated embedding, örn. llama-text-embed-v2)
PINECONE_INDEX_NAME=

# Opsiyonel: Namespace (boş bırakılırsa default kullanılır)
# PINECONE_NAMESPACE=

# Records JSON dosyası ile çalıştırırken (npm run pinecone:insert):
# RECORDS_FILE=./scripts/records.example.json

# Örnek record üretirken (RECORDS_FILE yoksa):
# SAMPLE_COUNT=5

# ----- Test OpenAI (Responses API - kayıtlı prompt) -----
# OpenAI API anahtarı - https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Kayıtlı prompt ID (OpenAI dashboard'dan)
OPENAI_PROMPT_ID=
# Prompt versiyonu (varsayılan: 2)
# OPENAI_PROMPT_VERSION=2

# ----- PostgreSQL (DB schema endpoint) -----
# Tercih: tek satır bağlantı
# DATABASE_URL=postgres://user:pass@localhost:5432/dbname
#
# Alternatif: ayrı değişkenler
# PGHOST=localhost
# PGPORT=5432
# PGDATABASE=dbname
# PGUSER=user
# PGPASSWORD=pass
#
# kentrehberi_poi/features-by-bbox için en fazla dönen satır (varsayılan 5000, üst sınır 50000)
# KENTREHBERI_POI_BBOX_MAX_FEATURES=5000

# ----- Ses → metin (transcribe_audio.py) -----
# WHISPER_BACKEND=auto
# Türkçe için dil kodu (otomatik algılama: auto veya boş)
# WHISPER_LANGUAGE=tr
# Apple Silicon MLX: önerilen small (çoklu dil, Türkçe için uygun)
# MLX_WHISPER_MODEL=mlx-community/whisper-small-mlx
# Yedek faster-whisper (CPU; MPS desteklenmez)
# FASTER_WHISPER_MODEL=small
# FASTER_WHISPER_DEVICE=cpu
# FASTER_WHISPER_COMPUTE=int8
